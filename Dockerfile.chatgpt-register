# chatgpt-register sidecar：debian + winehq-stable(32位) + ChatGPTRegister.exe + Go 执行器。
#
# 为何 debian 而非 alpine：wine 依赖 glibc，alpine(musl) 跑不了；与 web 镜像同为 debian
# bookworm，glibc 版本一致。为何 winehq-stable：注册机 exe(Go 编译的 PE32)依赖 bcryptprimitives
# 等较新 DLL，debian 自带 wine 偏旧；winehq-stable(>=9)齐全且经验证可跑通。

# --- 构建 Go 执行器 ---
FROM golang:1.24-bookworm AS builder
WORKDIR /src
COPY services/chatgpt-register/go.mod ./
RUN go mod download
COPY services/chatgpt-register/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/chatgpt-register .

# --- 运行时：wine + exe ---
FROM debian:bookworm-slim AS runner

# 安装 winehq-stable(含 32 位)。winehq 仓库提供较新的稳定版，避免 debian 自带 wine
# 缺少注册机所需 DLL 的问题。
RUN dpkg --add-architecture i386 && \
    apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates wget gnupg && \
    mkdir -pm755 /etc/apt/keyrings && \
    wget -O /etc/apt/keyrings/winehq-archive.key https://dl.winehq.org/wine-builds/winehq.key && \
    wget -NP /etc/apt/sources.list.d/ https://dl.winehq.org/wine-builds/debian/dists/bookworm/winehq-bookworm.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends winehq-stable && \
    apt-get purge -y wget gnupg && apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# 非 root 运行；wineprefix 须可写并预初始化，避免首次请求时初始化拖慢/失败。
RUN useradd --create-home --uid 1001 app
USER app
ENV HOME=/home/app
ENV WINEPREFIX=/home/app/.wine
ENV WINEARCH=win32
ENV WINEDEBUG=-all
# wine 需要 XDG_RUNTIME_DIR，否则打印噪声警告；指向 home 下的可写目录（0700）。
ENV XDG_RUNTIME_DIR=/home/app/.xdg
# 关闭 Gecko/Mono 安装弹窗（注册机为纯控制台 HTTP 工具，不需要它们）。
ENV WINEDLLOVERRIDES="mscoree,mshtml="

# 构建期初始化 win32 wineprefix 并等待 wineserver 退出，使运行时无需联网初始化。
RUN mkdir -p "$XDG_RUNTIME_DIR" && chmod 700 "$XDG_RUNTIME_DIR" && \
    wineboot --init && wineserver -w

# 烤入注册机 exe（仓库根的「注册机」目录，已被 git 跟踪）。
COPY --chown=app:app ["注册机/ChatGPTRegister.exe", "/app/ChatGPTRegister.exe"]
COPY --from=builder --chown=app:app /out/chatgpt-register /usr/local/bin/chatgpt-register

ENV CHATGPT_REGISTER_BIND=":3023"
ENV CHATGPT_REGISTER_EXE_PATH="/app/ChatGPTRegister.exe"
ENV CHATGPT_REGISTER_WINE_PREFIX="/home/app/.wine"

EXPOSE 3023
ENTRYPOINT ["chatgpt-register"]
